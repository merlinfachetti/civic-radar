# ───────────────────────────────────────────────────────────
# CivicRadar — Environment Variables (example)
# ───────────────────────────────────────────────────────────
# Copie para `.env` no diretório respectivo (apps/api/.env, apps/web/.env.local)

# ── API (apps/api) ─────────────────────────────────────────
CIVIC_RADAR_ENV=development
CIVIC_RADAR_DATABASE_URL=sqlite+aiosqlite:///./data/civic_radar.db
# Produção (Postgres):
# CIVIC_RADAR_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/civicradar

CIVIC_RADAR_LOG_LEVEL=INFO
CIVIC_RADAR_LOG_FORMAT=console
# Em produção:
# CIVIC_RADAR_LOG_FORMAT=json

CIVIC_RADAR_CORS_ORIGINS=http://localhost:3000
CIVIC_RADAR_METRICS_ENABLED=false
CIVIC_RADAR_RATE_LIMIT_PER_MINUTE=60

# Crawlers
CIVIC_RADAR_RAW_SNAPSHOT_PATH=./data/raw_snapshots
CIVIC_RADAR_USER_AGENT=CivicRadar/0.1 (+https://github.com/merlinfachetti/civic-radar)

# ── Web (apps/web) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
