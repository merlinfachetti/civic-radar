# ───────────────────────────────────────────────────────────
# CivicRadar — Environment Variables (example)
# ───────────────────────────────────────────────────────────
# Copy to `.env` in the relevant directory (apps/api/.env, apps/web/.env.local).
# Production values are commented next to each line for reference.

# ── API (apps/api) ─────────────────────────────────────────
CIVIC_RADAR_ENV=development
# Production: CIVIC_RADAR_ENV=production

CIVIC_RADAR_DATABASE_URL=sqlite+aiosqlite:///./data/civic_radar.db
# Production (SQLite on a mounted volume — current Railway setup):
# CIVIC_RADAR_DATABASE_URL=sqlite+aiosqlite:////data/civic_radar.db
# Production alternative (Postgres):
# CIVIC_RADAR_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/civicradar

CIVIC_RADAR_LOG_LEVEL=INFO
CIVIC_RADAR_LOG_FORMAT=console
# Production: CIVIC_RADAR_LOG_FORMAT=json

CIVIC_RADAR_CORS_ORIGINS=http://localhost:3000
# Production must include every public web origin, comma-separated:
# CIVIC_RADAR_CORS_ORIGINS=https://civic-radar.aldenmerlin.com,https://civic-radar.vercel.app

CIVIC_RADAR_METRICS_ENABLED=false
CIVIC_RADAR_RATE_LIMIT_PER_MINUTE=60
CIVIC_RADAR_SEED_ON_STARTUP=false
# Set CIVIC_RADAR_SEED_ON_STARTUP=true to populate the DB on container start.
# The seed is idempotent — restarts never duplicate rows.

# Crawlers
CIVIC_RADAR_RAW_SNAPSHOT_PATH=./data/raw_snapshots
# Production: CIVIC_RADAR_RAW_SNAPSHOT_PATH=/data/raw_snapshots
CIVIC_RADAR_USER_AGENT=CivicRadar/0.1 (+https://github.com/merlinfachetti/civic-radar)

# ── Web (apps/web) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production:
# NEXT_PUBLIC_API_URL=https://civic-radar-production.up.railway.app
# INTERNAL_API_URL=https://civic-radar-production.up.railway.app
# NEXT_PUBLIC_SITE_URL=https://civic-radar.aldenmerlin.com
